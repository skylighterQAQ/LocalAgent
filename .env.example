# LLM Provider Configuration
# Options: "ollama" or "openai"
LLM_PROVIDER=ollama

# Ollama Configuration (for local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120

# OpenAI Configuration (for cloud LLM)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: For OpenAI-compatible APIs (Azure, local endpoints, etc.)
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=gpt-3.5-turbo

# Wanqing Configuration (Kuaishou internal LLM service)
# Get your API key from Wanqing platform
WANQING_API_KEY=
WANQING_BASE_URL=https://wanqing-api.corp.kuaishou.com/api/gateway/v1/endpoints
WANQING_DEFAULT_MODEL=ep-116jmc-1778070434284074729
WANQING_TIMEOUT=120

# Agent Configuration
AGENT_MAX_ITERATIONS=50
AGENT_VERBOSE=true

# Memory Configuration
MEMORY_ENABLE_LONG_TERM=true
MEMORY_CHROMA_PATH=./.local_agent/memory
MEMORY_MAX_SHORT_TERM=20

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Security
REQUIRE_CONFIRMATION=false
MAX_FILE_SIZE_MB=100

# MCP (Model Context Protocol)
MCP_CONFIG_PATH=./config/mcp.json
MCP_ENABLED=true
